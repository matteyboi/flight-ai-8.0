# Example environment variables for local development and production
# Copy this to `.env` and edit values as appropriate.

# Server
PORT=5050

# Admin credentials (replace in production)
ADMIN_USER=admin
ADMIN_PASS=password

# Alternatively, use a single bearer token for admin access
# If ADMIN_TOKEN_ONLY=true then Basic Auth is disabled and ADMIN_TOKEN must be set.
ADMIN_TOKEN=
ADMIN_TOKEN_ONLY=false

# Set to true to enable stricter startup checks in `backend/app.py`.
PRODUCTION=false

# Optional OpenAI configuration for lesson generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Notes:
# - Do NOT commit secrets. Keep `.env` out of version control.
# - The project uses a local SQLite DB at `backend/progress.db` by default.# Copy this to `.env` and fill values for local development
# Redis URL for rate limiter storage (optional). If unset, in-memory storage is used.
# Example: RATELIMIT_STORAGE_URL=redis://:password@redis-host:6379/0
RATELIMIT_STORAGE_URL=redis://redis:6379/0
# Admin basic auth
ADMIN_USER=admin
ADMIN_PASS=password

# Optional: a long random token for Bearer auth (preferred over embedding passwords in UIs)
# Example: export ADMIN_TOKEN=4f9b7c2a-... (use a secure generator)
# Leave blank to disable token auth.
ADMIN_TOKEN=

# When true, require `ADMIN_TOKEN` (Bearer) and disallow Basic auth. Default: false
# Set to `true` to enforce token-only admin access.
ADMIN_TOKEN_ONLY=false

# Backend port
PORT=5051
