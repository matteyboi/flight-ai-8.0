# Production Environment Example
# Copy to .env and update values for deployment

PORT=5050

# Admin credentials (replace these in production)
ADMIN_USER=your_admin
ADMIN_PASS=your_strong_password

# Alternatively, use a single bearer token for admin access
ADMIN_TOKEN=your_long_secret_token
ADMIN_TOKEN_ONLY=true

# Enable strict startup checks
PRODUCTION=true

# Redis-backed rate limiting (recommended for production)
RATELIMIT_STORAGE_URL=redis://:password@redis-host:6379/0

# Optional OpenAI configuration
OPENAI_API_KEY=
